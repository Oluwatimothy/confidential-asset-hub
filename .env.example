# ==============================================================================
# Confidential Asset Hub — Environment Variables
# Copy to .env.local and fill in values
# ==============================================================================

# ── WalletConnect Project ID (required for RainbowKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── RPC Endpoints
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.public.blastapi.io
NEXT_PUBLIC_MAINNET_RPC_URL=https://eth-mainnet.public.blastapi.io

# ── Zama Relayer URL (proxied via Next.js API route to avoid CORS)
NEXT_PUBLIC_RELAYER_URL_SEPOLIA=https://relayer.testnet.zama.org
NEXT_PUBLIC_RELAYER_URL_MAINNET=https://relayer.zama.org

# ── Zama Registry Contract Addresses
# Ethereum Mainnet
NEXT_PUBLIC_REGISTRY_ADDRESS_MAINNET=0xeb5015fF021DB115aCe010f23F55C2591059bBA0
# Sepolia Testnet (update when official Sepolia address is published)
NEXT_PUBLIC_REGISTRY_ADDRESS_SEPOLIA=0xeb5015fF021DB115aCe010f23F55C2591059bBA0

# ── FHEVM Host Contract Addresses — Sepolia
NEXT_PUBLIC_ACL_CONTRACT_SEPOLIA=0xf0Ffdc93b7E186bC2f8CB3dAA75D86d1930A433D
NEXT_PUBLIC_KMS_VERIFIER_SEPOLIA=0xbE0E383937d564D7FF0BC3b46c51f0bF8d5C311A
NEXT_PUBLIC_INPUT_VERIFIER_SEPOLIA=0xBBC1fFCdc7C316aAAd72E807D9b0272BE8F84DA0
NEXT_PUBLIC_DECRYPTION_ADDRESS_SEPOLIA=0x5D8BD78e2ea6bbE41f26dFe9fdaEAa349e077478
NEXT_PUBLIC_INPUT_VERIFICATION_ADDRESS_SEPOLIA=0x483b9dE06E4E4C7D35CCf5837A1668487406D955

# ── FHEVM Host Contract Addresses — Mainnet
NEXT_PUBLIC_ACL_CONTRACT_MAINNET=0xcA2E8f1F656CD25C01F05d0b243Ab1ecd4a8ffb6
NEXT_PUBLIC_KMS_VERIFIER_MAINNET=0x77627828a55156b04Ac0DC0eb30467f1a552BB03

# ── Gateway Chain ID
NEXT_PUBLIC_GATEWAY_CHAIN_ID_SEPOLIA=10901

# ── Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CUSTOM_PAIRS=true
